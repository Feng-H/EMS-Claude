# Bind to localhost by default so the VPS host Nginx can reverse proxy safely.
EMS_BIND_HOST=127.0.0.1

# Docker service ports exposed on the host.
EMS_FRONTEND_PORT=3000
EMS_BACKEND_PORT=9000
EMS_POSTGRES_PORT=5432
EMS_REDIS_PORT=6379

# LLM Configuration (SiliconFlow, OpenAI, etc.)
EMS_LLM_PROVIDER=openai
EMS_LLM_BASE_URL=https://api.siliconflow.cn/v1
EMS_LLM_API_KEY=your_api_key_here
EMS_LLM_MODEL=deepseek-ai/DeepSeek-V3

# Lark (Feishu) Integration
EMS_LARK_APP_ID=your_lark_app_id
EMS_LARK_APP_SECRET=your_lark_app_secret
EMS_LARK_VERIFICATION_TOKEN=your_verification_token
EMS_LARK_ENCRYPT_KEY=your_encrypt_key

# Application Settings
EMS_DOMAIN=ems.example.com
EMS_APP_BASE_URL=https://${EMS_DOMAIN}
EMS_APP_QR_CODE_BASE_URL=https://${EMS_DOMAIN}/equipment/
